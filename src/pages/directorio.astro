import Layout from "../layouts/Layout.astro";
---

<script>
  import { idx, directoryData } from "../utils/idx";

  function search() {
    const inputElement = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    if (!inputElement) {
      console.error("Elemento #searchInput no encontrado");
      return;
    }

    const query = inputElement.value.trim();
    const searchResultsDiv = document.getElementById("searchResults");

    if (!searchResultsDiv) {
      console.error("Elemento #searchResults no encontrado");
      return;
    }

    // Si el input está vacío, limpiar los resultados y salir
    if (query === "") {
      searchResultsDiv.innerHTML = "";
      return;
    }

    const results = idx.search(query);
    searchResultsDiv.innerHTML = "";

    if (results.length === 0) {
      searchResultsDiv.innerHTML = "<p>No se encontraron resultados.</p>";
      return;
    }

    results.forEach((result) => {
      const doc = directoryData.find((d) => d.id === result.ref);
      if (!doc) {
        console.warn(`Documento con id ${result.ref} no encontrado`);
        return;
      }

      const resultElement = document.createElement("div");
      resultElement.innerHTML = `
      <div class="flex flex-col justify-center gap-10">
        <div class="bg-white w-auto h-[320px] shadow-lg rounded-2xl p-4 mb-2 flex flex-col items-center group relative overflow-hidden px-10">
          <img src="${doc.image || ""}" alt="${doc.name || "Sin imagen"}" class="block mx-auto w-[150px] h-[150px] object-contain mb-5 rounded-full">
          <p class="text-md font-semibold -mx-10"><strong>${doc.name || "Nombre desconocido"}</strong></p>
          <p class="text-gray-500 text-md text-center">${doc.ciudad || "Ciudad desconocida"}</p>
          <p class="text-gray-500 text-md text-center">${doc.profesion || "Profesión desconocida"}</p>
          <div
              class="absolute inset-0 bg-[#113545] bg-opacity-100 text-white flex flex-col items-center justify-center text-center px-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"
            >
              <p class="text-dm">${doc.direccion || ""}</p>
              <br />
              <p class="text-dm">${doc.gerencia || ""}</p>
              <br />
              <p class="text-dm">Cargo:${doc.position || "Posición desconocida"}</p>
              <br />
              <a
                href="https://mail.google.com/mail/?view=cm&fs=1&to=${doc.email || ""}"
                target="_blank"
                class="text-white-600 underline text-center break-all w-full"
              >
                ${doc.email || "Correo electrónico desconocido"}
              </a>
            </div>
        </div> 
      </div>
      `;

      searchResultsDiv.appendChild(resultElement);
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("searchButton");
    const inputElement = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;

    if (button) {
      button.addEventListener("click", search);
    } else {
      console.error("Botón #searchButton no encontrado");
    }

    if (inputElement) {
      // Llamar a la función search() cada vez que el usuario escriba
      inputElement.addEventListener("input", search);

      // Permitir que Enter también ejecute la búsqueda
      inputElement.addEventListener("keypress", (event) => {
        if (event.key === "Enter") {
          search();
        }
      });
    } else {
      console.error("Input #searchInput no encontrado");
    }
  });
</script>

<Layout title="Directorio | Ecosistema Humboldt">
  <main>
    <header class="container block mx-auto max-w-[1280px]">
      <img src="../img/Banner-directorio.png" class="max-w-full" />
    </header>
    <div class="max-w-[80%] mx-auto">
      <span
        class="text-azul-humboldt text-md mb-10 block text-center font-bold animate-pulse"
      >
        ¡Conoce más sobre nuestro equipo! Pasa el mouse por encima de cada
        tarjeta.
      </span>
    </div>
    <div>
      <div
        class="flex justify-center items-center my-4"
        class="container mx-auto"
      >
        <input
          type="text"
          id="searchInput"
          placeholder="Buscar por nombre, cargo, ciudad o profesión"
          class="w-96"
        />
        <button
          id="searchButton"
          class="bg-black text-white py-3 px-14 max-w-fit ml-4 rounded-3xl font-light"
          >Buscar
        </button>
      </div>
    </div>
    <div class="w-full flex justify-center my-4">
      <div id="searchResults"></div>
    </div>
  </main>
</Layout>

