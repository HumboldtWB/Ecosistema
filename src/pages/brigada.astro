---
import Layout from "../layouts/Layout.astro";
import Menu from "../components/Menu.astro";
---

<Layout title="Brigadistas | Ecosistema Humboldt">
  <main>
    <section class="max-w-[90%] md:max-w-[70%] mx-auto mt-28">
      <ul role="list" class="link-card-grid">
        <Menu
          href="copasst"
          title="Copasst"
          classes="py-2 px-3"
          targets="_self"
        />
        <Menu
          href="convivencia"
          title="Comité de convivencia"
          classes="py-2 px-3"
          targets="_self"
        />
        <Menu
          href="#brigada"
          title="Brigadistas"
          classes="active py-2 px-3"
          targets="_self"
        />
      </ul>
    </section>
    <div class="max-w-[90%] mx-auto">
      <span
        onclick="history.back()"
        class="text-azul-humboldt text-base mt-10 mb-3 block cursor-pointer"
      >
        <img src="img/volver.svg" alt="volver" width="20" class="inline mr-3" />
        Volver
      </span>
      <h1 class="text-black text-4xl mt-32 mb-3 font-bold">Brigadistas</h1>
    </div>

