                    d="M9 5 5 1 1 5"></path>
                </svg>
              </button>
            </h2>
            <div
              id="accordion-collapse-body-3"
              class="hidden"
              aria-labelledby="accordion-collapse-heading-3"
            >
              <div class="p-5">
                <p class="mb-2 text-base">
                  <a
                    href="docs/AGR-GH-R-01Reglamento-interno-de-trabajo.pdf"
                    target="_blank"
                    rel="noopener noreferrer">Reglamento interno de trabajo</a
                  >
                </p>
                <p class="mb-2 text-base">
                  <a
