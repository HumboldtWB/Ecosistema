<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Acordeón
    const questions = document.querySelectorAll(".faq-question");

    questions.forEach((btn) => {
      btn.addEventListener("click", () => {
        const parent = btn.closest(".faq-item");
        if (!parent) return;

        const answer = parent.querySelector(".faq-answer");
        const icon = parent.querySelector(".faq-icon");

        if (!answer) return;

        const isOpen = answer.classList.contains("open");

        // Cierra todos
        document
          .querySelectorAll(".faq-answer")
          .forEach((a) => a.classList.remove("open"));
        document
          .querySelectorAll(".faq-icon")
          .forEach((i) => (i.textContent = "+"));

        // Abre el actual
        if (!isOpen) {
          answer.classList.add("open");
          if (icon) icon.textContent = "−";
        }
      });
    });

    // Buscador (TIPADO)
    const input = document.querySelector("#faqSearch");
    const faqItems = document.querySelectorAll(".faq-item");

    const normalize = (text: string) =>
      String(text || "")
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "");

    const filterFaq = () => {
      if (!input) return;

      const typedInput = input as HTMLInputElement;
      const searchValue = normalize(typedInput.value.trim());

      faqItems.forEach((item) => {
        const typedItem = item as HTMLElement;

        const questionEl = typedItem.querySelector(".faq-question");
        const answerEl = typedItem.querySelector(".faq-answer");

        const questionText = normalize(
          questionEl ? questionEl.textContent || "" : "",
        );
        const answerText = normalize(
          answerEl ? answerEl.textContent || "" : "",
        );

        const match =
          searchValue === "" ||
          questionText.includes(searchValue) ||
          answerText.includes(searchValue);

        typedItem.style.display = match ? "block" : "none";
      });
    };
    if (input) input.addEventListener("input", filterFaq);
  });
</script>

