---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Preguntas frecuentes | Talento Humano | Ecosistema Humboldt">
  <main>
    <!-- ✅ ESTE DIV es el que tiene el fondo (NO el footer) -->
    <div class="th-page">
      <!-- Volver -->
      <div class="max-w-[90%] mx-auto w-full flex justify-start">
        <a
          href="/missolicitudes"
          class="text-azul-humboldt text-base mt-10 mb-3 flex items-center cursor-pointer"
        >
          <img src="/img/volver.svg" alt="volver" width="20" class="mr-3" />
          <span>Volver</span>
        </a>
      </div>

      <section class="mt-16 pb-16">
        <div class="max-w-[90%] md:max-w-[85%] mx-auto">
          <div
            class="th-content grid grid-cols-1 lg:grid-cols-2 gap-10 items-start"
          >
            <!-- Columna izquierda vacía (solo para empujar el contenido a la derecha en desktop) -->
            <div class="hidden lg:block"></div>

            <!-- Columna derecha -->
            <div class="th-card">
              <h1 class="text-black text-5xl font-bold leading-tight">
                Preguntas frecuentes de <span class="font-bold"
                  >Talento Humano</span
                >
              </h1>

              <div
                class="mt-10 space-y-6 text-gray-700 text-base leading-relaxed max-w-xl"
              >
                <p>
                  En esta sección podrás consultar respuestas rápidas a las
                  preguntas más comunes sobre procesos, solicitudes y
                  herramientas de Talento Humano.
                </p>
                <p>
                  Usa el buscador para encontrar una pregunta por palabra clave.
                </p>
              </div>

              <hr class="faq-divider mt-8" />

              <!-- BUSCADOR -->
              <div class="mt-6">
                <label class="block text-sm font-semibold text-gray-800 mb-2">
                  Buscar pregunta
                </label>

                <input
                  id="faqSearch"
                  type="text"
                  placeholder="Ej: vacaciones, certificados, permisos..."
                  class="faq-search"
                />
              </div>

              <!-- LISTA FAQ -->
              <div class="mt-8 space-y-4" id="faqList">
                <div class="faq-item">
                  <button type="button" class="faq-question">
                    ¿Dónde solicito mis vacaciones?
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    Puedes solicitar tus vacaciones desde el <b
                      >Portal de Autogestión Novasoft</b
                    >. Allí podrás gestionar la solicitud y hacer seguimiento al
                    estado.

                    <div class="faq-links">
                      <a href="#" class="faq-pill">
                        Mira el instructivo aquí <span>›</span>
                      </a>

                      <a href="#" class="faq-pill">
                        Mira el tutorial aquí <span>›</span>
                      </a>
                    </div>
                  </div>
                </div>

                <div class="faq-item">
                  <button type="button" class="faq-question">
                    ¿Cómo descargo mi desprendible de nómina?
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    Puedes descargar tu desprendible de nómina desde <b
                      >Xtickets</b
                    >. Si no tienes acceso, valida con Talento Humano el usuario
                    habilitado.
                  </div>
                </div>

                <div class="faq-item">
                  <button type="button" class="faq-question">
                    ¿Dónde puedo descargar certificados laborales?
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    Los certificados laborales los puedes generar directamente
                    en el
                    <b>Portal de Autogestión Novasoft</b>.
                  </div>
                </div>

                <div class="faq-item">
                  <button type="button" class="faq-question">
                    ¿Qué hago si tengo problemas de acceso a una plataforma?
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    Si presentas inconvenientes, intenta primero con tu usuario
                    institucional. Si el problema continúa, realiza una
                    solicitud por <b>Xtickets</b> o contacta al área responsable.
                  </div>
                </div>

                <div class="faq-item">
                  <button type="button" class="faq-question">
                    ¿Dónde reporto una solicitud o caso de Talento Humano?
                    <span class="faq-icon">+</span>
                  </button>
                  <div class="faq-answer">
                    Puedes reportar casos y solicitudes a través de <b
                      >Xtickets</b
                    >, según la categoría asignada.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>
